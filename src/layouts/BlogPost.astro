---
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import { Toc } from "@/components/blogs/Toc";
import MobileToc from "@/components/blogs/MobileToc";
import CloudImage from "@/components/common/cloud-image-astro.astro";
import BlogImage from "@/components/blogs/blog-image";

type NavLink = { slug: string; title: string };

type Props = CollectionEntry<"blog">["data"] & {
  headings?: MarkdownHeading[];
  readMin?: number;
  prev?: NavLink;
  next?: NavLink;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroWidth,
  heroHeight,
  heroThumbhash,
  headings,
  readMin,
  prev,
  next,
} = Astro.props;

const author = {
  name: "Barry Song",
  title: "什么都会点软件工程师",
};

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}.${String(
    d.getDate(),
  ).padStart(2, "0")}`;

const hasToc = (headings?.length ?? 0) >= 2;
---

<BaseLayout title={title} description={description} ogImage={heroImage}>
  <article class="mx-auto max-w-[720px] px-6 pt-[72px]">
    <a
      href="/"
      class="back-link inline-flex items-center gap-1.5 font-mono text-[12.5px] tracking-[0.04em] text-[var(--ink-3)] transition-colors"
    >
      <svg
        viewBox="0 0 16 16"
        fill="none"
        class="h-[13px] w-[13px] rotate-180"
        aria-hidden="true"
      >
        <path
          d="M4 12L12 4M12 4H6M12 4V10"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
       返回
    </a>

    {
      heroImage && heroWidth && heroHeight ? (
        <BlogImage
          client:load
          src={heroImage}
          alt={title}
          width={heroWidth}
          height={heroHeight}
          thumbhash={heroThumbhash}
          zoomable={false}
          className="mt-6 rounded-[2px]"
        />
      ) : heroImage ? (
        <div class="mt-6 overflow-hidden rounded-[2px]">
          <CloudImage src={heroImage} alt={title} class="w-full" />
        </div>
      ) : null
    }

    <header class="mt-6">
      <h1
        class="m-0 text-[clamp(24px,4vw,34px)] font-bold leading-[1.2] tracking-[-0.025em] text-[var(--ink)]"
      >
        {title}
      </h1>
      <div class="mt-4 flex items-center gap-2.5 text-[13px] text-[var(--ink-3)]">
        <time datetime={pubDate.toISOString()} class="whitespace-nowrap font-mono">
          {fmtDate(pubDate)}
        </time>
        {
          readMin && (
            <>
              <span class="text-[var(--ink-4)]">·</span>
              <span class="whitespace-nowrap font-mono">{readMin} 分钟阅读</span>
            </>
          )
        }
        {
          updatedDate && (
            <>
              <span class="text-[var(--ink-4)]">·</span>
              <span class="whitespace-nowrap font-mono">
                更新于 {fmtDate(updatedDate)}
              </span>
            </>
          )
        }
      </div>
    </header>

    <div
      class="prose mt-8 wrap-break-word max-w-none prose-headings:scroll-mt-[84px]"
    >
      <slot />
    </div>

    <nav class="mt-[72px] grid grid-cols-2 gap-6 border-t border-[var(--line)] pt-8">
      {
        prev ? (
          <a href={`/blogs/${prev.slug}`} class="pn-btn flex flex-col items-start gap-2 text-left">
            <span class="font-mono text-[11.5px] tracking-[0.06em] text-[var(--ink-3)]">
              ← 上一篇
            </span>
            <span class="text-[13.5px] font-medium leading-[1.4] text-[var(--ink)] transition-colors">
              {prev.title}
            </span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a href={`/blogs/${next.slug}`} class="pn-btn flex flex-col items-end gap-2 text-right">
            <span class="font-mono text-[11.5px] tracking-[0.06em] text-[var(--ink-3)]">
              下一篇 →
            </span>
            <span class="text-[13.5px] font-medium leading-[1.4] text-[var(--ink)] transition-colors">
              {next.title}
            </span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </article>

  {/* 桌面端目录 — 固定在右侧留白 */}
  {
    hasToc && (
      <aside class="fixed top-[150px] z-[5] hidden max-h-[calc(100vh-174px)] w-[200px] flex-col [left:calc(50%+392px)] min-[1181px]:flex">
        <Toc client:load headings={headings} />
      </aside>
    )
  }

  {/* 移动端目录 */}
  {
    hasToc && (
      <div class="min-[1181px]:hidden">
        <MobileToc client:load headings={headings} author={author} />
      </div>
    )
  }
</BaseLayout>
