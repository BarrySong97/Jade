---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import CodeWrapper from "@/components/blogs/code-wrapper.astro";
import MdxImage from "@/components/blogs/mdx-image.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, index) => {
    // 列表按时间从新到旧排序：上一篇 = 更新的一篇，下一篇 = 更旧的一篇
    const newer = posts[index - 1];
    const older = posts[index + 1];
    const toNav = (p?: CollectionEntry<"blog">) =>
      p
        ? { slug: p.id.replace(/\.mdx?$/, ""), title: p.data.title }
        : undefined;

    return {
      params: { slug: post.id.replace(/\.mdx?$/, "") },
      props: { post, prev: toNav(newer), next: toNav(older) },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);

// 估算阅读时间（中英文混排，约 350 字/分钟）
const text = post.body ?? "";
const wordCount =
  (text.match(/[一-龥]/g)?.length ?? 0) +
  (text.match(/[a-zA-Z0-9]+/g)?.length ?? 0);
const readMin = Math.max(1, Math.round(wordCount / 350));

// 自定义 MDX 组件映射 - 替换默认的 pre 和 img 标签
const components = {
  pre: CodeWrapper,
  img: MdxImage,
};
---

<BlogPost
  {...post.data}
  headings={headings}
  readMin={readMin}
  prev={prev}
  next={next}
>
  <Content components={components} />
</BlogPost>
